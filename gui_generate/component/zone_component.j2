    {% set selector_index = i + 5 + 1 %}
    {% set selector_slot = "s"~selector_index %}
        {{
        d.zone_icon(
            name = "zone_selector" ~ selector_slot ~ "_" ~ name,
            px = px + len * 6 + i//2 * half_len,
            py = py + i%2 * half_len,
            len = half_len,
            text = "bca_zone_icon_selector_"~selector_slot,
            effect = "bca_planet_setting_" ~ zone_slot ~"_"~ selector_slot
        )
        }}
    {% endfor %}
    {% endif %}
