{% macro main_zone_setting(district_len, is_selector) -%}
    {% set len = 50 %}
    {% set x_pos = district_len * 0.65 %}
    {% set y_pos = 40 %}

    {{
    main_zone_setting_unit(
        name = 'z1',
        px = x_pos,
        py = y_pos,
        len = len,
        zone_slot = "z1",
        is_selector = is_selector
    )
    }}

    {{
    main_zone_setting_unit(
        name = 'z2',
        px = x_pos,
        py = y_pos + len + 15,
        len = len,
        zone_slot = "z2",
        is_selector = is_selector
    )
    }}

    {{
    main_zone_secondary_district_setting(
        district_len = district_len,
        px = x_pos + len * 3.5 + 15,
        py = y_pos,
        len = len,
        is_selector = is_selector
    )
    }}


{%- endmacro %}


