{% macro zone_setting_selector_length(len, option_count, large_count = 5) -%}
    {% if option_count <= large_count %}
        {{ len * option_count }}
    {% else %}
        {{ len * (large_count + (option_count-large_count + 1)//2/2 + 1/8) }}
    {% endif %}
{%- endmacro %}

{% macro main_zone_setting_unit(name, px, py, len, zone_slot, is_selector) -%}

    {% if not is_selector %}
    {{ d.dynamic_district_icon(name, px, py, len, zone_slot) }}

{#    effectButtonType = {#}
{#        name = "{{ name }}_zone_name_frame"#}
{#        quadTextureSprite = "GFX_dark_green_area"#}
{#        position = { x = {{ px + len }} y = {{ py }} }#}
{#        size = { x = {{ len * 2 }} y = {{ len }} }#}
{#        alwaysTransparent = yes#}
{#    }#}

    effectButtonType = {
        name = "{{ name }}_zone_name_text"
        quadTextureSprite = "GFX_dark_green_area"

        position = { x = {{ px + len }} y = {{ py }} }
        size = { x = {{ len * 2.5 }} y = {{ len }} }
        font = "cg_16b"
        buttonText = "BCA_ZONE_SELECTION_{{ zone_slot }}"

        tooltipText = "BCA_ZONE_SELECTION_TOOLTIP"
        delayedTooltipText = "BCA_ZONE_SELECTION_DESC"
{#        alwaysTransparent = yes#}
    }

    {% else %}


    {% for option_count in range(1, 16) %}
    effectButtonType = {
        name = "{{ name }}_zone_select_frame_{{ option_count }}"
        quadTextureSprite = "GFX_dark_green_frame_area"
        position = { x = {{ px + len }} y = {{ py }} }
        size = { x = {{ zone_setting_selector_length(len, option_count) }} y = {{ len }} }
        effect = "bca_planet_setting_selector_frame_{{ zone_slot }}_{{ option_count }}"
        alwaysTransparent = yes
    }
    {% endfor %}
    {% for i in range(1,6) %}
    {% set selector_slot = "s"~i %}
        {{
        d.zone_icon(
            name = "zone_selector" ~ selector_slot ~ "_" ~ name,
            px = px + len * i,
            py = py,
            len = len,
            text = "bca_zone_icon_selector_" ~ selector_slot,
            effect = "bca_planet_setting_" ~ zone_slot ~"_"~ selector_slot
        )
        }}
    {% endfor %}

    {% set half_len = len/2 %}

