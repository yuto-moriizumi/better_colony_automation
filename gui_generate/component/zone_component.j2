{% macro slider_bar(name, x, y, len, height, effect_prefix, count = 20) -%}
{% set margin = 3 %}
{% set bar_len = len - margin * 0.5 %}
{% set button_len = bar_len//count %}
{% set button_height = height - margin * 2 %}
{% set button_begin_x = (len - button_len * count)/2 %}
{% set button_begin_y = margin %}
containerWindowType = {
    name = "{{ name }}_slider"
    position = { x = {{ x }} y = {{ y }} }
    size = { width = {{ len }} height = {{ height }} }
    background = {
        name = "districts_window_background"
        spriteType = "GFX_interface_list_dark"
        alwaysTransparent = yes
    }

    {% for i in range(count) %}
        effectButtonType = {
            name = "{{ name }}_bar_{{ i }}_1"
            position = { x = {{ button_begin_x + i * button_len }} y = {{ button_begin_y }} }
            size = { x = {{ button_len }} y = {{ button_height }} }
            quadTextureSprite = "GFX_primary_district_bar_built"
            effect = "bca_planet_setting_slider_primary_district_built_{{ i + 1 }}"
        }
    {% endfor %}
    {% for i in range(count) %}
        effectButtonType = {
            name = "{{ name }}_bar_{{ i }}_3"
            position = { x = {{ button_begin_x + i * button_len }} y = {{ button_begin_y }} }
            size = { x = {{ button_len }} y = {{ button_height }} }
            quadTextureSprite = "GFX_secondary_district_bar_built"
            effect = "bca_planet_setting_slider_secondary_district_built_{{ i + 1 }}"
        }
    {% endfor %}
    {% for i in range(count) %}
        effectButtonType = {
            name = "{{ name }}_bar_{{ i }}_2"
            position = { x = {{ button_begin_x + i * button_len }} y = {{ button_begin_y }} }
            size = { x = {{ button_len }} y = {{ button_height }} }
            quadTextureSprite = "GFX_primary_district_bar_plan"
            effect = "bca_planet_setting_slider_primary_district_plan_{{ i + 1 }}"
        }
    {% endfor %}
    {% for i in range(count) %}
        effectButtonType = {
            name = "{{ name }}_bar_{{ i }}4"
            position = { x = {{ button_begin_x + i * button_len }} y = {{ button_begin_y }} }
            size = { x = {{ button_len }} y = {{ button_height }} }
            quadTextureSprite = "GFX_secondary_district_bar_plan"
            effect = "bca_planet_setting_slider_secondary_district_plan_{{ i + 1 }}"
        }
    {% endfor %}
}
{%- endmacro %}

{% macro main_zone_secondary_district_setting(district_len, px, py, len, is_selector) -%}

        {{
