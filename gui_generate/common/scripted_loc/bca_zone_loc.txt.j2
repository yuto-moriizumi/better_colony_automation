{% import 'component/planet_flag_ps.j2' as pf with context -%}
{% import 'component/planet_variable.j2' as v -%}

{% for zone_slot in ['z1','z2','z3','z4','z5','zx']%}
defined_text = {
	name = BCA_ZONE_SELECTION_ICON_{{ zone_slot }}_script
    {% for item in zones_info %}
	text = {
	    trigger = {
            has_planet_flag = {{pf.flag_selected_zone_type(zone_slot, item.type)}}
        }
	    localization_key =  bca_zone_icon_large_{{item.type}}
	}
    {% endfor %}
}
{% endfor %}

{% for i in range(1,16)%}
{% set selector_slot = "s"~i %}
{% set icon_type = 'large' if i <= 5 else 'small' %}
defined_text = {
	name = BCA_ZONE_SELECTOR_ICON_{{ selector_slot }}_script
    {% for item in zones_info %}
    {% set type = item.type %}
	text = {
	    trigger = {
            has_planet_flag = {{ pf.flag_zone_option_type_elected_idx(selector_slot, type) }}
        }
	    localization_key =  bca_zone_icon_{{ icon_type }}_{{type}}
	}
    {% endfor %}
}
{% endfor %}

{% for zone_slot in ['z1','z2','z3','zx']%}
defined_text = {
	name = BCA_ZONE_SELECTION_{{ zone_slot }}_script
{#	random = no#}
    {% for item in zones_info %}
    {% for zone in item.zones %}
	text = {
	    trigger = {
            has_planet_flag = {{pf.flag_selected_zone(zone_slot, zone)}}
        }
	    localization_key = {{ zone }}
	}
    {% endfor %}
    {% endfor %}
    default = BCA_ZONE_SELECTION_DEFAULT
}
{% endfor %}

defined_text = {
	name = BCA_DISTRICT_PLAN_FREE_COUNT_script
    value = value:bca_num_free_secondary_districts_plan
}

{% for i in range(3,6) %}
{% set zone_slot = "z"~i %}
defined_text = {
	name = BCA_DISTRICT_PLAN_COUNT_{{ zone_slot }}_script
    value = {{v.var_district_num_plan(zone_slot)}}
}
{% endfor %}
