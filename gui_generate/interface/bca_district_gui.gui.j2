        {{ z.main_zone_setting(district_len=district_len, is_selector = False) }}
        {{ z.secondary_zone_setting(district_len=district_len, is_selector = False) }}

        {{ z.main_zone_setting(district_len=district_len, is_selector = True) }}
        {{ z.secondary_zone_setting(district_len=district_len, is_selector = True) }}


        effectButtonType = {
            name = 'on_designation_change_mask12'
            quadTextureSprite = "GFX_dark_area"
			size = { width = {{ main_panel_len }} height = 178 }
			position = { x = 0 y = 0 }
            effect = "bca_planet_setting_show_up_on_designation_changed"
            alwaysTransparent = no
        }

        effectButtonType = {
            name = 'on_designation_change_mask3'
            quadTextureSprite = "GFX_dark_area"
			size = { width = {{ district_len }} height = 178 }
			position = { x = -{{ district_len }} y = 0 }
            effect = "bca_planet_setting_show_up_on_designation_changed"
            alwaysTransparent = no
            orientation = upper_right
        }

        {% set option_button_width = 200 %}
        {% set option_button_height = 100 %}
        {% set option_button_gap = 40 %}

        effectButtonType = {
            name = "maintain_settings_on_designation_changed"
            quadTextureSprite = "GFX_tiles_frame_button"

            position = { x = {{ main_panel_len/2 - option_button_width - option_button_gap }} y = {{ district_height/2 - option_button_height/2 }} }
            size = { x = {{ option_button_width }} y = {{ option_button_height }} }
            font = "cg_16b"
            buttonText = "BCA_ZONE_SELECTION_MAINTAIN_SETTINGS_ON_DESIGNATION_CHANGED"

            tooltipText = "BCA"
            effect = "bca_planet_setting_maintain_settings_on_designation_changed"
        }

        effectButtonType = {
            name = "reset_settings_on_designation_changed"
            quadTextureSprite = "GFX_tiles_frame_button"

            position = { x = {{ main_panel_len/2 + option_button_gap }} y = {{ district_height/2 - option_button_height/2 }} }
            size = { x = {{ option_button_width }} y = {{ option_button_height }} }
            font = "cg_16b"
            buttonText = "BCA_ZONE_SELECTION_RESET_SETTINGS_ON_DESIGNATION_CHANGED"

            tooltipText = "BCA_ZONE_SELECTION_TOOLTIP"
            effect = "bca_planet_setting_reset_settings_on_designation_changed"
        }

	}


