{% import 'component/planet_components.j2' as p -%}
{% import 'component/zone_component.j2' as z with context -%}

{% set district_len = 285 %}
{% set district_height = 178 %}
{% set main_panel_len = 570 %}

guiTypes = {
    # 3 width
	containerWindowType = {
		name = "bca_planet_district_entry_gui"
		size = { width = 861 height = 178 }
{#		background = {#}
{#			name = "districts_window_background"#}
{#			spriteType = "GFX_dark_area"#}
{#			alwaysTransparent = yes#}
{#		}#}
		containerWindowType = {
			name = "function1"
			size = { width = {{ main_panel_len }} height = 178 }
			background = {
				name = "districts_window_background"
				spriteType = "GFX_interface_list_dark"
				alwaysTransparent = yes
			}
            {{ p.setting_title(name = 'f1title',
                               text = 'PRIMARY_DISTRICT_SETTINGS',
                               width = district_len * 2 ) }}

            {% set panel_x = 15 %}
            {% set button_len = 120 %}
            {% set button_height = 35 %}
            {% set panel_y1 = 40 + 50/2 - button_height/2 %}
            {% set panel_y2 = 40 + 50 + 15 + 50/2 - button_height/2 %}
            {{
            p.toggle_button(
                name = "auto_demolish",
                x = panel_x, y = panel_y1, len = button_height,
                tex_prefix = "GFX_bca_button_demolish",
                effect_prefix = "bca_planet_setting_auto_destruction"
            )
            }}

            {{
            p.toggle_button_text(
                name = "auto_demolish_text",
                x = panel_x + button_height, y = panel_y1,
                sx = button_len, sy = button_height,
                text = "BCA_PLANET_SETTING_AUTO_DESTRUCTION",
                tooltip = "BCA_PLANET_SETTING_AUTO_DESTRUCTION_DESC",
                tex_prefix = "GFX_bca_button_standard",
                effect_prefix = "bca_planet_setting_auto_destruction"
            )
            }}

            {{
            p.toggle_button(
                name = "auto_prebuild",
                x = panel_x, y = panel_y2, len = button_height,
                tex_prefix = "GFX_bca_button_preconstruction",
                effect_prefix = "bca_planet_setting_preconstruction"
            )
            }}
            {{
            p.toggle_button_text(
                name = "auto_prebuild_text",
                x = panel_x + button_height, y = panel_y2,
                sx = button_len, sy = button_height,
                text = "BCA_PLANET_SETTING_PRECONSTRUCTION",
                tooltip = "BCA_PLANET_SETTING_PRECONSTRUCTION_DESC",
                tex_prefix = "GFX_bca_button_standard",
                effect_prefix = "bca_planet_setting_preconstruction"
            )
            }}


		}

        effectButtonType = {
            name = "function3"
            quadTextureSprite = "GFX_interface_list_dark"
			size = { width = {{ district_len }} height = 178 }
			position = { x = -{{ district_len }} y = 0 }
            effect = "bca_planet_setting_secondary_zone_show_up"
            alwaysTransparent = yes
            orientation = upper_right
        }



        effectButtonType = {
            name = 'f3title'
            position = { x = -{{ district_len }} y = 5 }
            orientation = upper_right
            size = { x = {{ district_len }} y = 25 }
            font = "font_text_14"
            buttonText = "SECONDARY_DISTRICT_SETTINGS"
            quadTextureSprite = "GFX_tiled_window_transparent"
            maxWidth = {{ district_len }}
            maxHeight = 25
            format = center
            vertical_alignment = center
            alwaysTransparent = yes
            effect = "bca_planet_setting_secondary_zone_show_up"
        }
